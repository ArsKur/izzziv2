// ════════════════════════════════════════════════
// RENDER
// ════════════════════════════════════════════════
function render(data) {
  const name  = data.bizName  || 'AutoPro Detailing';
  const city  = data.bizCity  || 'Москва';
  const phone = data.phone    || '+7 (495) 000-00-00';
  const addr  = data.address  || `${city}, ул. Гаражная, 1`;

  document.title = name;
  document.getElementById('ld-name').textContent = name;

  // Название — берём первые 2 слова, разбиваем
  const words = name.replace(/\s+/g,' ').split(' ');
  const logoMain = words[0].toUpperCase();
  const logoSub  = words.slice(1).join('').toUpperCase() || 'PRO';
  [document.getElementById('nav-logo'), document.getElementById('footer-logo')].forEach(el => {
    if (el) el.innerHTML = `${logoMain}<span>${logoSub}</span>`;
  });

  document.getElementById('footer-copy').textContent = `© ${new Date().getFullYear()} ${name} · Профессиональный детейлинг`;

  // Phone
  ['topbar-phone','nav-phone'].forEach(id => {
    const el = document.getElementById(id);
    if (!el) return;
    el.href = `tel:${phone.replace(/\D/g,'')}`;
    if (id === 'topbar-phone') el.innerHTML = `<span>Запись:</span>${phone}`;
    else el.textContent = phone;
  });

  // Hero
  document.getElementById('hero-tag').textContent = data.bizType || 'Профессиональный детейлинг';
  const tp = (data.hero_title || 'Ваш\nавтомобиль\nзаслуживает\nбольшего').split('\n');
  document.getElementById('hero-title').innerHTML =
    tp.map((p,i) => i === tp.length-1
      ? `<span class="red italic">${p}</span>`
      : p).join('<br>');
  document.getElementById('hero-desc').textContent = data.hero_desc || '';

  // Stats
  animateStat('hs-1', 2400, '+');
  animateStat('hs-2', 12, 'лет');
  animateStat('hs-3', 94, '%');

  // Services booking select
  const bfSvc = document.getElementById('bf-service');
  (data.products || getDemoData().products).forEach(p => {
    const o = document.createElement('option');
    o.value = p.name; o.textContent = `${p.name} — от ${parseInt(p.price).toLocaleString('ru-RU')} ₽`;
    bfSvc.appendChild(o);
  });

  // Calculator service options — sync with products
  const calcSvcEl = document.getElementById('calc-service');
  if (data.products && data.products.length) {
    calcSvcEl.innerHTML = '';
    data.products.forEach((p, i) => {
      const btn = document.createElement('button');
      btn.className = `calc-opt${i===0?' active':''}`;
      btn.dataset.group = 'svc';
      btn.dataset.val = p.price || '5000';
      btn.dataset.label = p.name;
      btn.dataset.dur = p.features && p.features[0] ? '' : '';
      btn.textContent = p.name;
      btn.onclick = function(){ calcSelect(this); };
      calcSvcEl.appendChild(btn);
    });
    updateCalc();
  }

  // Contacts block
  const bc = document.getElementById('booking-contacts');
  bc.innerHTML = `
    <div class="bc-row"><div class="bc-label">Телефон</div><div class="bc-val"><a href="tel:${phone.replace(/\D/g,'')}">${phone}</a></div></div>
    <div class="bc-row"><div class="bc-label">Адрес</div><div class="bc-val">${addr}</div></div>
    <div class="bc-row"><div class="bc-label">Режим</div><div class="bc-val">Пн–Вс 09:00–21:00 · Без выходных</div></div>
    <div class="bc-row"><div class="bc-label">Email</div><div class="bc-val"><a href="mailto:${data.email||'info@auto.ru'}">${data.email||'info@auto.ru'}</a></div></div>
  `;

  // Build sections
  buildServices(data.products || getDemoData().products);
  buildGallery(data.gallery || getDemoData().gallery);
  buildProcess();
  buildGuarantees();

  // Modal defaults
  const price = parseInt(data.avg_check) || 18000;
  document.getElementById('m-title').textContent = data.product_name || 'Детейлинг';
  document.getElementById('m-price').innerHTML = `от ${price.toLocaleString('ru-RU')} <span>₽</span>`;

  // Images
  loadImg('hero-img', data.hero_image_query || 'luxury car garage dark detailing professional');
}

// ── IMAGE LOADER ──────────────────────────────────
async function loadImg(imgId, query) {
  try {
    const r = await fetch('/image?q=' + encodeURIComponent(query));
    if (!r.ok) throw 0;
    const url = URL.createObjectURL(await r.blob());
    const img = document.getElementById(imgId);
    if (!img) return;
    img.src = url; img.style.display = 'block';
    img.previousElementSibling && (img.previousElementSibling.style.display = 'none');
  } catch(e) {}
}

// ── SERVICES ──────────────────────────────────────
function buildServices(products) {
  const grid = document.getElementById('services-grid');
  grid.innerHTML = '';
  products.slice(0,6).forEach((p, i) => {
    const feats = Array.isArray(p.features) ? p.features : [];
    const price = parseInt(p.price) || 0;
    grid.innerHTML += `
      <div class="svc-card" onclick="openModalFor('${p.name.replace(/'/g,"\\'")}', ${price})">
        <div class="svc-num">0${i+1}</div>
        <div class="svc-name">${p.name}</div>
        <div class="svc-desc">${p.desc || ''}</div>
        <div class="svc-tags">${feats.slice(0,3).map(f=>`<span class="svc-tag">${f}</span>`).join('')}</div>
        <div class="svc-bottom">
          <div class="svc-price">от ${price.toLocaleString('ru-RU')} ₽</div>
        </div>
      </div>`;
  });
}

// ── GALLERY ───────────────────────────────────────
