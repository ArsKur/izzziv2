// ── CALCULATOR ────────────────────────────────────
let calcState = { body: { val:1, label:'Седан' }, svc: { val:3500, label:'Комплексная мойка', dur:'2ч' }, cond: { val:1, label:'Хорошее' } };

function calcSelect(btn) {
  const group = btn.dataset.group;
  document.querySelectorAll(`[data-group="${group}"]`).forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  calcState[group] = { val: parseFloat(btn.dataset.val), label: btn.dataset.label, dur: btn.dataset.dur || '' };
  updateCalc();
}

function updateCalc() {
  const price = Math.round(calcState.svc.val * calcState.body.val * calcState.cond.val / 100) * 100;
  document.getElementById('cr-body').textContent  = calcState.body.label;
  document.getElementById('cr-svc').textContent   = calcState.svc.label;
  document.getElementById('cr-cond').textContent  = calcState.cond.label;
  document.getElementById('cr-price').innerHTML   = `${price.toLocaleString('ru-RU')} <span>₽</span>`;
  document.getElementById('cr-dur').textContent   = calcState.svc.dur ? `Время: ~${calcState.svc.dur}` : '';
}

function bookFromCalc() {
  const price = Math.round(calcState.svc.val * calcState.body.val * calcState.cond.val / 100) * 100;
  openModalFor(calcState.svc.label, price);
}

// ── STAT ANIMATION ────────────────────────────────
function animateStat(id, target, unit) {
  const el = document.getElementById(id);
  if (!el) return;
  const dur = 1600; const t0 = performance.now();
  const step = now => {
    const t = Math.min((now - t0) / dur, 1);
    const v = Math.round(target * (1 - Math.pow(1-t, 3)));
    el.innerHTML = `${v}<span class="unit">${unit}</span>`;
    if (t < 1) requestAnimationFrame(step);
    else el.innerHTML = `${target}<span class="unit">${unit}</span>`;
  };
  requestAnimationFrame(step);
}

// ── SCROLL REVEAL ─────────────────────────────────
const ro = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) { e.target.classList.add('visible'); ro.unobserve(e.target); }
  });
}, { threshold: 0.08 });
document.querySelectorAll('.reveal').forEach(el => ro.observe(el));

// ── MODAL ─────────────────────────────────────────
function openModal() { document.getElementById('modal').classList.add('active'); }
function openModalFor(title, price) {
  document.getElementById('m-eyebrow').textContent = 'Запись на услугу';
  document.getElementById('m-title').textContent = title || 'Детейлинг';
  document.getElementById('m-price').innerHTML = price > 0
    ? `от ${price.toLocaleString('ru-RU')} <span>₽</span>` : 'По договорённости';
  openModal();
}
function closeModal() {
  document.getElementById('modal').classList.remove('active');
  document.getElementById('m-success').classList.remove('show');
  document.getElementById('m-form').style.display = 'block';
}
function handleOvClick(e) { if (e.target === e.currentTarget) closeModal(); }
function simulatePay() {
  const btns = document.querySelectorAll('.m-submit, .bf-submit');
  btns.forEach(b => { b.textContent = 'Отправляем...'; b.disabled = true; });
  setTimeout(() => {
    document.getElementById('m-form').style.display = 'none';
    document.getElementById('m-success').classList.add('show');
    document.getElementById('modal').classList.add('active');
    btns.forEach(b => {
      b.disabled = false;
      b.textContent = b.classList.contains('bf-submit') ? 'Записаться на осмотр' : 'Подтвердить запись';
    });
  }, 1500);
}
function fmtCard(el) {
  let v = el.value.replace(/\D/g,'').substring(0,16);
  el.value = v.replace(/(.{4})/g,'$1 ').trim();
}
function fmtExpiry(el) {
  let v = el.value.replace(/\D/g,'').substring(0,4);
  if (v.length >= 2) v = v.slice(0,2) + ' / ' + v.slice(2);
  el.value = v;
}

