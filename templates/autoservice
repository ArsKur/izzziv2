// INIT
// ════════════════════════════════════════════════
window.addEventListener('DOMContentLoaded', () => {
  const payload = new URLSearchParams(window.location.search).get('data');
  if (payload) {
    try { render(JSON.parse(decodeURIComponent(atob(payload)))); }
    catch(e) { console.error(e); render(getDemoData()); }
  } else {
    render(getDemoData());
  }
  setTimeout(() => {
    document.getElementById('ld').classList.add('hidden');
    setTimeout(() => document.getElementById('ld').remove(), 500);
  }, 900);
});
