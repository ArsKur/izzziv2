  const grid = document.getElementById('gallery-grid');
  grid.innerHTML = '';
  gallery.slice(0,5).forEach((item, i) => {
    const imgId = `ba-img-${i}`;
    const isWide = i === 0;
    grid.innerHTML += `
      <div class="ba-cell${isWide ? ' wide' : ''}">
        <div class="ba-ph">
          <svg viewBox="0 0 80 60" fill="none"><path d="M5 45h70M15 45c0-8 6-15 15-20l10-3h20l10 3c8 4 10 12 10 20" stroke="#f0f0f0" stroke-width="1.2" fill="none" opacity=".5"/><circle cx="25" cy="48" r="6" stroke="#f0f0f0" stroke-width="1.2" fill="none" opacity=".5"/><circle cx="55" cy="48" r="6" stroke="#f0f0f0" stroke-width="1.2" fill="none" opacity=".5"/></svg>
