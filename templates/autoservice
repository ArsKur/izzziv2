<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Детейлинг</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,600;0,700;0,900;1,700&family=Barlow:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg:    #0a0a0a;
  --bg2:   #111111;
  --bg3:   #191919;
  --red:   #e8000d;
  --red2:  #ff1a24;
  --coal:  #0a0a0a;
  --white: #f0f0f0;
  --muted: rgba(240,240,240,.45);
  --muted2:rgba(240,240,240,.18);
  --line:  rgba(240,240,240,.08);
  --line2: rgba(240,240,240,.14);
  --cond:  'Barlow Condensed', sans-serif;
  --body:  'Barlow', sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  background:var(--bg);color:var(--white);
  font-family:var(--body);font-size:15px;line-height:1.6;
  overflow-x:hidden;-webkit-font-smoothing:antialiased;
}

/* ── LOADING ─── */
#ld{
  position:fixed;inset:0;z-index:9999;background:var(--bg);
  display:flex;align-items:center;justify-content:center;flex-direction:column;gap:20px;
  transition:opacity .5s,visibility .5s;
}
#ld.hidden{opacity:0;visibility:hidden;pointer-events:none}
.ld-bar{width:160px;height:2px;background:var(--line2);overflow:hidden}
.ld-fill{height:100%;background:var(--red);animation:ldFill 1s cubic-bezier(.4,0,.2,1) both;transform-origin:left}
@keyframes ldFill{from{transform:scaleX(0)}to{transform:scaleX(1)}}
.ld-name{font-family:var(--cond);font-size:13px;font-weight:600;color:var(--muted);letter-spacing:.18em;text-transform:uppercase}

/* ── TOPBAR ─── */
.topbar{
  background:var(--red);padding:8px 48px;
  display:flex;align-items:center;justify-content:space-between;
}
.topbar-phone{font-family:var(--cond);font-size:14px;font-weight:700;color:#fff;letter-spacing:.04em;text-decoration:none}
.topbar-phone span{font-weight:400;opacity:.8;margin-right:8px}
.topbar-hours{font-size:12px;color:rgba(255,255,255,.8);letter-spacing:.04em}
.topbar-msg{font-family:var(--cond);font-size:12px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.7)}

/* ── NAVBAR ─── */
nav{
  position:sticky;top:0;z-index:100;
  background:rgba(10,10,10,.96);backdrop-filter:blur(20px);
  border-bottom:2px solid var(--red);
  display:flex;align-items:center;padding:0 48px;height:60px;
  transition:transform .3s;
}
.nav-logo{
  font-family:var(--cond);font-size:22px;font-weight:900;
  color:var(--white);letter-spacing:-.01em;margin-right:40px;
  text-transform:uppercase;flex-shrink:0;
}
.nav-logo span{color:var(--red)}
.nav-links{display:flex;gap:0;list-style:none;flex:1}
.nav-links a{
  display:block;padding:0 16px;line-height:60px;
  font-family:var(--cond);font-size:14px;font-weight:600;
  color:var(--muted);text-decoration:none;letter-spacing:.06em;text-transform:uppercase;
  transition:color .2s;border-right:1px solid var(--line);
}
.nav-links a:hover{color:var(--white)}
.nav-links li:first-child a{border-left:1px solid var(--line)}
.nav-right{display:flex;gap:12px;align-items:center;margin-left:auto}
.nav-phone{font-family:var(--cond);font-size:16px;font-weight:700;color:var(--white);text-decoration:none}
.btn-book{
  padding:9px 22px;
  background:var(--red);border:none;color:#fff;
  font-family:var(--cond);font-size:14px;font-weight:700;
  letter-spacing:.08em;text-transform:uppercase;cursor:pointer;transition:background .2s;
  clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);
}
.btn-book:hover{background:var(--red2)}

/* ── HERO ─── */
.hero{
  position:relative;min-height:100vh;overflow:hidden;
  display:grid;grid-template-columns:1fr 1fr;
}
/* diagonal split */
.hero::after{
  content:'';position:absolute;top:0;bottom:0;
  left:50%;width:120px;transform:translateX(-50%);
  background:linear-gradient(to right,transparent,rgba(232,0,13,.15),transparent);
  pointer-events:none;z-index:2;
}
/* animated scan line */
.hero::before{
  content:'';position:absolute;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--red),transparent);
  animation:scanLine 4s linear infinite;z-index:3;pointer-events:none;
}
@keyframes scanLine{0%{top:-1px;opacity:0}10%{opacity:1}90%{opacity:.3}100%{top:100%;opacity:0}}

.hero-l{
  position:relative;z-index:1;
  display:flex;flex-direction:column;justify-content:flex-end;
  padding:80px 64px 72px 72px;
  background:linear-gradient(to right,var(--bg) 60%,transparent);
}
/* red vertical accent */
.hero-l::before{
  content:'';position:absolute;left:44px;top:120px;bottom:80px;
  width:3px;background:var(--red);
  clip-path:polygon(0 0,100% 4px,100% calc(100% - 4px),0 100%);
}

.hero-tag{
  display:flex;align-items:center;gap:12px;
  font-family:var(--cond);font-size:11px;font-weight:700;
  letter-spacing:.22em;text-transform:uppercase;color:var(--red);
  margin-bottom:24px;
}
.hero-tag::before{content:'';width:28px;height:2px;background:var(--red)}

.hero-title{
  font-family:var(--cond);
  font-size:clamp(56px,8vw,110px);
  font-weight:900;line-height:.95;
  letter-spacing:-.02em;text-transform:uppercase;
  color:var(--white);margin-bottom:24px;
}
.hero-title .red{color:var(--red)}
.hero-title .italic{font-style:italic}

.hero-desc{
  font-size:16px;color:var(--muted);line-height:1.7;
  max-width:400px;margin-bottom:40px;font-weight:300;
}

.hero-cta{display:flex;align-items:center;gap:16px;margin-bottom:56px}
.btn-primary{
  display:inline-flex;align-items:center;gap:10px;
  padding:14px 32px;background:var(--red);border:none;color:#fff;
  font-family:var(--cond);font-size:16px;font-weight:700;
  letter-spacing:.08em;text-transform:uppercase;cursor:pointer;transition:all .25s;
  clip-path:polygon(10px 0%,100% 0%,calc(100% - 10px) 100%,0% 100%);
}
.btn-primary:hover{background:var(--red2);transform:translateY(-2px);box-shadow:0 12px 40px rgba(232,0,13,.4)}
.btn-secondary{
  font-family:var(--cond);font-size:14px;font-weight:600;
  letter-spacing:.08em;text-transform:uppercase;color:var(--muted);
  background:none;border:none;cursor:pointer;
  border-bottom:1px solid var(--line2);padding:2px 0;transition:color .2s,border-color .2s;
}
.btn-secondary:hover{color:var(--white);border-color:var(--white)}

.hero-specs{
  display:flex;gap:40px;
  padding-top:28px;border-top:1px solid var(--line);
}
.hs-item{}
.hs-num{
  font-family:var(--cond);font-size:38px;font-weight:900;
  color:var(--white);line-height:1;letter-spacing:-.02em;
}
.hs-num .unit{font-size:18px;color:var(--red);font-weight:700}
.hs-label{font-size:12px;color:var(--muted);margin-top:4px;letter-spacing:.04em}

/* hero right — image */
.hero-r{
  position:relative;overflow:hidden;background:var(--bg2);
}
.hero-r-ph{
  position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
  background:linear-gradient(135deg,var(--bg2) 0%,var(--bg3) 100%);
}
.hero-r-ph svg{width:120px;height:120px;opacity:.08}
#hero-img{
  width:100%;height:100%;object-fit:cover;display:none;
  position:absolute;inset:0;
}
.hero-r::after{
  content:'';position:absolute;inset:0;pointer-events:none;
  background:linear-gradient(to left,transparent 40%,rgba(10,10,10,.7) 100%),
             linear-gradient(to top,rgba(10,10,10,.5) 0%,transparent 40%);
}
/* speed lines overlay */
.speed-lines{
  position:absolute;inset:0;z-index:1;pointer-events:none;
  background:repeating-linear-gradient(
    85deg,
    transparent,transparent 40px,
    rgba(232,0,13,.03) 40px,rgba(232,0,13,.03) 41px
  );
}

/* ── BRANDS STRIP ─── */
.brands-strip{
  background:var(--bg2);border-top:1px solid var(--line);border-bottom:1px solid var(--line);
  padding:20px 48px;display:flex;align-items:center;gap:0;overflow:hidden;
}
.brands-label{
  font-family:var(--cond);font-size:10px;font-weight:700;
  letter-spacing:.2em;text-transform:uppercase;color:var(--muted2);
  flex-shrink:0;margin-right:40px;white-space:nowrap;
}
.brands-track{display:flex;gap:48px;align-items:center;overflow:hidden}
.brand-name{
  font-family:var(--cond);font-size:14px;font-weight:700;
  color:var(--muted2);letter-spacing:.1em;text-transform:uppercase;
  transition:color .2s;cursor:default;white-space:nowrap;
}
.brand-name:hover{color:var(--muted)}

/* ── CALCULATOR ─── */
.calc-section{
  background:var(--bg2);
  border-bottom:1px solid var(--line);
  padding:72px 48px;
}
.calc-header{margin-bottom:40px}
.section-eyebrow{
  font-family:var(--cond);font-size:11px;font-weight:700;
  letter-spacing:.22em;text-transform:uppercase;color:var(--red);margin-bottom:12px;
}
.section-title{
  font-family:var(--cond);font-size:clamp(32px,4vw,56px);
  font-weight:900;text-transform:uppercase;letter-spacing:-.01em;
  color:var(--white);line-height:1;
}
.section-title em{font-style:italic;color:var(--red)}

.calc-grid{display:grid;grid-template-columns:1fr 340px;gap:40px;align-items:start}

.calc-form{display:flex;flex-direction:column;gap:0}
.calc-step{
  border-bottom:1px solid var(--line);padding:24px 0;
}
.calc-step:last-child{border-bottom:none}
.calc-step-label{
  font-family:var(--cond);font-size:11px;font-weight:700;
  letter-spacing:.18em;text-transform:uppercase;color:var(--muted2);margin-bottom:14px;
}
.calc-options{display:flex;flex-wrap:wrap;gap:8px}
.calc-opt{
  padding:9px 18px;
  background:transparent;border:1px solid var(--line2);
  color:var(--muted);font-family:var(--cond);font-size:14px;font-weight:600;
  letter-spacing:.06em;text-transform:uppercase;cursor:pointer;transition:all .2s;
}
.calc-opt:hover{border-color:var(--muted2);color:var(--white)}
.calc-opt.active{background:var(--red);border-color:var(--red);color:#fff}
/* skewed options */
.calc-opt{clip-path:polygon(6px 0%,100% 0%,calc(100% - 6px) 100%,0% 100%)}

/* result card */
.calc-result{
  background:var(--bg3);border:1px solid var(--line2);
  border-top:3px solid var(--red);
  padding:32px 28px;position:sticky;top:80px;
}
.cr-title{
  font-family:var(--cond);font-size:12px;font-weight:700;
  letter-spacing:.18em;text-transform:uppercase;color:var(--muted2);margin-bottom:20px;
}
.cr-rows{display:flex;flex-direction:column;gap:0;margin-bottom:24px}
.cr-row{
  display:flex;justify-content:space-between;align-items:center;
  padding:10px 0;border-bottom:1px solid var(--line);
}
.cr-row:last-child{border-bottom:none}
.cr-key{font-size:13px;color:var(--muted);font-weight:300}
.cr-val{font-family:var(--cond);font-size:14px;font-weight:700;color:var(--white)}
.cr-total-row{
  display:flex;justify-content:space-between;align-items:flex-end;
  padding-top:20px;border-top:1px solid var(--line2);margin-top:4px;
}
.cr-total-label{font-family:var(--cond);font-size:12px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--muted)}
.cr-total-price{
  font-family:var(--cond);font-size:40px;font-weight:900;
  color:var(--white);letter-spacing:-.02em;line-height:1;
}
.cr-total-price span{font-size:18px;color:var(--red)}
.cr-dur{font-size:12px;color:var(--muted2);margin-top:4px;text-align:right}
.cr-book{
  width:100%;padding:14px;margin-top:20px;
  background:var(--red);border:none;color:#fff;
  font-family:var(--cond);font-size:15px;font-weight:700;
  letter-spacing:.1em;text-transform:uppercase;cursor:pointer;transition:background .2s;
  clip-path:polygon(10px 0%,100% 0%,calc(100% - 10px) 100%,0% 100%);
}
.cr-book:hover{background:var(--red2)}
.cr-note{font-size:11px;color:var(--muted2);text-align:center;margin-top:10px;letter-spacing:.04em}

/* ── SERVICES ─── */
.services-section{padding:72px 48px;background:var(--bg);border-bottom:1px solid var(--line)}
.services-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:2px;background:var(--line);margin-top:40px;
}
.svc-card{
  background:var(--bg2);padding:36px 30px;
  position:relative;overflow:hidden;cursor:pointer;transition:background .25s;
}
.svc-card:hover{background:var(--bg3)}
.svc-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:var(--red);transform:scaleX(0);transform-origin:left;transition:transform .3s;
}
.svc-card:hover::before{transform:scaleX(1)}
.svc-num{
  font-family:var(--cond);font-size:11px;font-weight:700;
  color:var(--red);letter-spacing:.18em;text-transform:uppercase;margin-bottom:14px;
}
.svc-name{
  font-family:var(--cond);font-size:24px;font-weight:700;
  text-transform:uppercase;color:var(--white);letter-spacing:-.01em;margin-bottom:10px;
}
.svc-desc{font-size:13px;color:var(--muted);line-height:1.65;font-weight:300;margin-bottom:20px}
.svc-tags{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:20px}
.svc-tag{
  font-family:var(--cond);font-size:11px;font-weight:600;
  letter-spacing:.08em;text-transform:uppercase;
  padding:3px 10px;background:rgba(232,0,13,.12);
  border:1px solid rgba(232,0,13,.25);color:rgba(232,0,13,.8);
}
.svc-bottom{
  display:flex;align-items:center;justify-content:space-between;
  padding-top:16px;border-top:1px solid var(--line);
}
.svc-price{font-family:var(--cond);font-size:22px;font-weight:900;color:var(--white);letter-spacing:-.02em}
.svc-dur{font-size:12px;color:var(--muted2);letter-spacing:.04em}

/* ── BEFORE/AFTER ─── */
.gallery-section{
  background:var(--bg);padding:72px 48px;
  border-bottom:1px solid var(--line);
}
.gallery-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:2px;background:var(--line);margin-top:40px;
}
.ba-cell{
  position:relative;aspect-ratio:4/3;overflow:hidden;
  background:var(--bg2);cursor:pointer;
}
.ba-cell:first-child{grid-column:span 2}
.ba-ph{
  position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
  background:var(--bg3);
}
.ba-ph svg{width:48px;height:48px;opacity:.12}
.ba-img-el{
  width:100%;height:100%;object-fit:cover;display:none;
  transition:transform .6s ease;
}
.ba-cell:hover .ba-img-el{transform:scale(1.04)}
.ba-overlay{
  position:absolute;inset:0;pointer-events:none;
  background:linear-gradient(to top,rgba(10,10,10,.7) 0%,transparent 50%);
  opacity:.7;transition:opacity .3s;
}
.ba-cell:hover .ba-overlay{opacity:.9}
.ba-caption{
  position:absolute;bottom:0;left:0;right:0;padding:20px 22px;
  display:flex;align-items:flex-end;justify-content:space-between;
}
.ba-name{
  font-family:var(--cond);font-size:18px;font-weight:700;
  text-transform:uppercase;color:var(--white);letter-spacing:.02em;
}
.ba-badge{
  font-family:var(--cond);font-size:10px;font-weight:700;
  letter-spacing:.12em;text-transform:uppercase;
  padding:4px 10px;background:var(--red);color:#fff;
}

/* ── PROCESS ─── */
.process-section{
  background:var(--bg2);padding:72px 48px;
  border-bottom:1px solid var(--line);
}
.process-steps{
  display:grid;grid-template-columns:repeat(5,1fr);
  gap:0;margin-top:48px;position:relative;
}
/* connecting line */
.process-steps::before{
  content:'';position:absolute;top:28px;left:10%;right:10%;height:1px;
  background:linear-gradient(to right,transparent,var(--line2) 20%,var(--red) 50%,var(--line2) 80%,transparent);
}
.process-step{
  display:flex;flex-direction:column;align-items:center;
  text-align:center;padding:0 16px;position:relative;
}
.ps-num{
  width:56px;height:56px;border-radius:0;
  border:2px solid var(--red);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--cond);font-size:20px;font-weight:900;color:var(--red);
  margin-bottom:20px;position:relative;z-index:1;
  background:var(--bg2);
  clip-path:polygon(8px 0%,100% 0%,calc(100% - 8px) 100%,0% 100%);
}
.process-step.done .ps-num{background:var(--red);color:#fff}
.ps-title{
  font-family:var(--cond);font-size:14px;font-weight:700;
  text-transform:uppercase;color:var(--white);letter-spacing:.04em;margin-bottom:8px;
}
.ps-desc{font-size:12px;color:var(--muted);line-height:1.6;font-weight:300}

/* ── GUARANTEES ─── */
.guarantees-section{
  background:var(--bg);padding:72px 48px;
  border-bottom:1px solid var(--line);
}
.guarantees-grid{
  display:grid;grid-template-columns:repeat(4,1fr);
  gap:2px;background:var(--line);margin-top:40px;
}
.guarantee-card{
  background:var(--bg2);padding:32px 28px;
  border-top:3px solid transparent;transition:all .3s;
}
.guarantee-card:hover{background:var(--bg3);border-top-color:var(--red)}
.gc-num{
  font-family:var(--cond);font-size:52px;font-weight:900;
  color:var(--red);line-height:1;letter-spacing:-.03em;margin-bottom:8px;
}
.gc-unit{font-size:20px;color:var(--muted)}
.gc-title{
  font-family:var(--cond);font-size:16px;font-weight:700;
  text-transform:uppercase;color:var(--white);letter-spacing:.04em;margin-bottom:6px;
}
.gc-desc{font-size:13px;color:var(--muted);font-weight:300;line-height:1.6}

/* ── BOOKING ─── */
.booking-section{
  background:var(--bg2);padding:72px 48px;
}
.booking-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start}
.booking-left{}
.booking-left .section-title{margin-bottom:16px}
.booking-desc{font-size:15px;color:var(--muted);line-height:1.7;font-weight:300;margin-bottom:32px}
.booking-contacts{display:flex;flex-direction:column;gap:16px}
.bc-row{
  display:flex;align-items:flex-start;gap:16px;
  padding:16px 0;border-bottom:1px solid var(--line);
}
.bc-row:last-child{border-bottom:none}
.bc-label{
  font-family:var(--cond);font-size:10px;font-weight:700;
  letter-spacing:.16em;text-transform:uppercase;color:var(--muted2);
  width:80px;flex-shrink:0;padding-top:2px;
}
.bc-val{font-size:14px;color:var(--white);font-weight:500;line-height:1.5}
.bc-val a{color:var(--red);text-decoration:none}

/* booking form */
.booking-form{
  background:var(--bg3);border:1px solid var(--line2);
  border-top:3px solid var(--red);padding:32px 28px;
}
.bf-title{
  font-family:var(--cond);font-size:16px;font-weight:700;
  text-transform:uppercase;letter-spacing:.08em;color:var(--white);margin-bottom:20px;
}
.bf-input{
  width:100%;padding:12px 14px;margin-bottom:12px;
  background:rgba(240,240,240,.05);border:1px solid var(--line2);
  color:var(--white);font-family:var(--body);font-size:14px;outline:none;
  transition:border-color .2s;
}
.bf-input::placeholder{color:var(--muted2)}
.bf-input:focus{border-color:var(--red)}
.bf-select{
  width:100%;padding:12px 14px;margin-bottom:12px;
  background:rgba(240,240,240,.05);border:1px solid var(--line2);
  color:var(--white);font-family:var(--body);font-size:14px;outline:none;
  cursor:pointer;
  background-image:url("data:image/svg+xml,%3Csvg width='12' height='8' viewBox='0 0 12 8' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L6 6L11 1' stroke='%23e8000d' stroke-width='1.5' stroke-linecap='round'/%3E%3C/svg%3E");
  background-repeat:no-repeat;background-position:right 14px center;
  appearance:none;
}
.bf-select option{background:#191919;color:var(--white)}
.bf-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.bf-submit{
  width:100%;padding:14px;margin-top:4px;
  background:var(--red);border:none;color:#fff;
  font-family:var(--cond);font-size:15px;font-weight:700;
  letter-spacing:.1em;text-transform:uppercase;cursor:pointer;transition:background .2s;
  clip-path:polygon(10px 0%,100% 0%,calc(100% - 10px) 100%,0% 100%);
}
.bf-submit:hover{background:var(--red2)}
.bf-note{font-size:11px;color:var(--muted2);text-align:center;margin-top:10px;letter-spacing:.04em}

/* ── FOOTER ─── */
footer{
  background:var(--bg2);border-top:2px solid var(--red);
  padding:40px 48px;
  display:grid;grid-template-columns:1fr auto auto auto;gap:60px;align-items:start;
}
.footer-logo{
  font-family:var(--cond);font-size:24px;font-weight:900;
  text-transform:uppercase;color:var(--white);
}
.footer-logo span{color:var(--red)}
.footer-copy{font-size:12px;color:var(--muted2);margin-top:8px;letter-spacing:.04em}
.footer-col h4{
  font-family:var(--cond);font-size:10px;font-weight:700;
  letter-spacing:.2em;text-transform:uppercase;color:var(--muted2);margin-bottom:14px;
}
.footer-col a{
  display:block;font-size:13px;color:var(--muted);
  text-decoration:none;margin-bottom:10px;transition:color .2s;letter-spacing:.02em;
}
.footer-col a:hover{color:var(--white)}

/* ── MODAL ─── */
.modal-ov{
  position:fixed;inset:0;z-index:1000;
  background:rgba(0,0,0,.8);backdrop-filter:blur(12px);
  display:flex;align-items:center;justify-content:center;
  opacity:0;visibility:hidden;transition:all .3s;
}
.modal-ov.active{opacity:1;visibility:visible}
.modal-box{
  background:var(--bg2);border:1px solid var(--line2);border-top:3px solid var(--red);
  padding:44px;width:100%;max-width:460px;position:relative;
  box-shadow:0 40px 80px rgba(0,0,0,.6);
}
.modal-x{
  position:absolute;top:16px;right:16px;
  background:var(--bg3);border:1px solid var(--line2);
  width:32px;height:32px;font-size:18px;line-height:1;
  color:var(--muted);cursor:pointer;transition:all .2s;
}
.modal-x:hover{color:var(--white);border-color:var(--muted2)}
.modal-eyebrow{
  font-family:var(--cond);font-size:11px;font-weight:700;
  letter-spacing:.18em;text-transform:uppercase;color:var(--red);margin-bottom:8px;
}
.modal-title{
  font-family:var(--cond);font-size:28px;font-weight:900;
  text-transform:uppercase;color:var(--white);margin-bottom:4px;letter-spacing:-.01em;
}
.modal-price{
  font-family:var(--cond);font-size:42px;font-weight:900;
  color:var(--white);margin-bottom:28px;line-height:1;letter-spacing:-.03em;
}
.modal-price span{color:var(--red)}
.m-input{
  width:100%;padding:12px 14px;margin-bottom:10px;
  background:rgba(240,240,240,.05);border:1px solid var(--line2);
  color:var(--white);font-family:var(--body);font-size:14px;outline:none;
  transition:border-color .2s;
}
.m-input::placeholder{color:var(--muted2)}
.m-input:focus{border-color:var(--red)}
.m-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.m-submit{
  width:100%;padding:14px;margin-top:4px;
  background:var(--red);border:none;color:#fff;
  font-family:var(--cond);font-size:15px;font-weight:700;
  letter-spacing:.1em;text-transform:uppercase;cursor:pointer;transition:background .2s;
  clip-path:polygon(10px 0%,100% 0%,calc(100% - 10px) 100%,0% 100%);
}
.m-submit:hover{background:var(--red2)}
.m-secure{text-align:center;font-size:11px;color:var(--muted2);margin-top:10px;letter-spacing:.04em}
.m-success{display:none;text-align:center;padding:20px 0}
.m-success.show{display:block}
.ms-icon{
  width:64px;height:64px;margin:0 auto 16px;border:2px solid var(--red);
  display:flex;align-items:center;justify-content:center;
  clip-path:polygon(10px 0%,100% 0%,calc(100% - 10px) 100%,0% 100%);
}
.ms-icon svg{width:28px;height:28px}
.ms-title{
  font-family:var(--cond);font-size:28px;font-weight:900;
  text-transform:uppercase;color:var(--white);margin-bottom:8px;letter-spacing:-.01em;
}
.ms-text{font-size:14px;color:var(--muted);line-height:1.7;font-weight:300}

/* ── REVEAL ─── */
.reveal{opacity:0;transform:translateY(20px);transition:opacity .7s ease,transform .7s ease}
.reveal.visible{opacity:1;transform:translateY(0)}

::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--red);border-radius:2px}
</style>
</head>
