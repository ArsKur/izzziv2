.of-btn.outline { background: transparent; border: 1px solid var(--line); color: var(--coal); }
.of-btn.outline:hover { border-color: var(--coal); }
.of-btn.filled { background: var(--ochre); color: var(--cream); }
.of-btn.filled:hover { background: var(--clay); }
.of-btn.dark { background: var(--cream); color: var(--coal); }
.of-btn.dark:hover { background: var(--ochre); color: var(--cream); }

