// ── BREATHING WIDGET ───────────────────────────────
let breathRunning = false;
let breathPhase = 'inhale'; // inhale | hold-in | exhale | hold-out
let breathSeconds = 4;
let breathTotal = 4;
let breathCycles = 0;
let breathTimer = null;
const PHASES = [
  { id: 'inhale',   label: 'Вдох',    dur: 4, progress: 'fill'  },
  { id: 'hold-in',  label: 'Держите', dur: 4, progress: 'full'  },
  { id: 'exhale',   label: 'Выдох',   dur: 6, progress: 'drain' },
  { id: 'hold-out', label: 'Пауза',   dur: 2, progress: 'empty' },
];
let phaseIdx = 0;
const CIRCUMFERENCE = 2 * Math.PI * 90; // 565.5

function toggleBreath() {
  if (breathRunning) {
    clearInterval(breathTimer);
    breathRunning = false;
    document.getElementById('breath-hint').textContent = 'Нажмите, чтобы продолжить';
  } else {
    breathRunning = true;
    document.getElementById('breath-hint').textContent = 'Нажмите, чтобы остановить';
    startPhase();
  }
}

function startPhase() {
  const phase = PHASES[phaseIdx];
  document.getElementById('breath-phase').textContent = phase.label;
  breathSeconds = phase.dur;
  breathTotal = phase.dur;
  document.getElementById('breath-count').textContent = breathSeconds;
  updateProgress(phase, breathSeconds, breathTotal);

  clearInterval(breathTimer);
  breathTimer = setInterval(() => {
    breathSeconds--;
    document.getElementById('breath-count').textContent = breathSeconds;
    updateProgress(phase, breathSeconds, breathTotal);
    if (breathSeconds <= 0) {
      clearInterval(breathTimer);
      phaseIdx = (phaseIdx + 1) % PHASES.length;
      if (phaseIdx === 0) {
        breathCycles++;
        updateCycleDots();
        if (breathCycles >= 5) {
          finishBreath(); return;
        }
      }
      if (breathRunning) startPhase();
    }
  }, 1000);
}

function updateProgress(phase, remaining, total) {
  const el = document.getElementById('breath-progress');
  let fraction;
  if (phase.progress === 'fill')  fraction = 1 - (remaining / total);
  if (phase.progress === 'full')  fraction = 1;
  if (phase.progress === 'drain') fraction = remaining / total;
  if (phase.progress === 'empty') fraction = 0;
  el.style.strokeDashoffset = CIRCUMFERENCE * (1 - fraction);
}

function updateCycleDots() {
  const dots = document.querySelectorAll('.cycle-dot');
  dots.forEach((d, i) => d.classList.toggle('done', i < breathCycles));
}

function finishBreath() {
  breathRunning = false;
  clearInterval(breathTimer);
  breathCycles = 0; phaseIdx = 0;
  updateCycleDots();
  document.getElementById('breath-phase').textContent = 'Готово';
  document.getElementById('breath-count').textContent = '✓';
  document.getElementById('breath-hint').textContent = 'Нажмите, чтобы начать снова';
  document.getElementById('breath-progress').style.strokeDashoffset = CIRCUMFERENCE;
}

// ── STAT ANIMATION ─────────────────────────────────
function animateStat(id, target) {
  const el = document.getElementById(id);
  if (!el) return;
  const dur = 1800; const start = performance.now();
  const step = (now) => {
    const t = Math.min((now - start) / dur, 1);
    const ease = 1 - Math.pow(1 - t, 3);
    el.textContent = Math.round(target * ease);
    if (t < 1) requestAnimationFrame(step);
    else el.textContent = target;
  };
  requestAnimationFrame(step);
}

// ── SCROLL REVEAL ──────────────────────────────────
const revealObs = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      e.target.classList.add('visible');
      revealObs.unobserve(e.target);
    }
  });
}, { threshold: 0.1 });
document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));

