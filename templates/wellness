<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Wellness</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
/* ════════════════════════════════════════════════
   YOGA / WELLNESS TEMPLATE
   Japonisme × Bauhaus. Тепло, воздух, телесность.
   Земляная охра · полынь · молоко · уголь
   ════════════════════════════════════════════════ */

:root {
  --cream:   #f5f0e8;
  --warm:    #ede5d4;
  --linen:   #e8dfc9;
  --ochre:   #c4954a;
  --ochre2:  #dba85c;
  --sage:    #7d8c74;
  --sage2:   #a3b09a;
  --clay:    #8b6347;
  --coal:    #1e1c18;
  --smoke:   #4a4740;
  --mist:    rgba(30,28,24,0.38);
  --mist2:   rgba(30,28,24,0.18);
  --line:    rgba(30,28,24,0.1);
  --line2:   rgba(30,28,24,0.06);
  --serif:   'Cormorant Garamond', Georgia, serif;
  --sans:    'DM Sans', sans-serif;
  --r:       40px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  background: var(--cream);
  color: var(--coal);
  font-family: var(--sans);
  font-size: 15px;
  line-height: 1.7;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

/* grain texture */
body::after {
  content: '';
  position: fixed; inset: 0; z-index: 9998; pointer-events: none;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  opacity: .55;
}

/* ── LOADING ─────────────────────────────────── */
#loading-screen {
  position: fixed; inset: 0; z-index: 9999;
  background: var(--cream);
  display: flex; align-items: center; justify-content: center;
  flex-direction: column; gap: 24px;
  transition: opacity .6s, visibility .6s;
}
#loading-screen.hidden { opacity: 0; visibility: hidden; pointer-events: none; }
.loading-symbol {
  width: 48px; height: 48px; position: relative;
}
.loading-symbol::before, .loading-symbol::after {
  content: '';
  position: absolute; border-radius: 50%;
  border: 1.5px solid var(--ochre);
}
.loading-symbol::before {
  inset: 0;
  animation: spinSlow 3s linear infinite;
}
.loading-symbol::after {
  inset: 10px;
  border-color: var(--sage);
  animation: spinSlow 2s linear infinite reverse;
}
@keyframes spinSlow { to { transform: rotate(360deg); } }
.loading-name {
  font-family: var(--serif); font-size: 18px; font-weight: 300;
  color: var(--smoke); letter-spacing: .15em; text-transform: uppercase;
}

/* ── NAVBAR ──────────────────────────────────── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center;
  padding: 0 48px; height: 60px;
  background: rgba(245,240,232,.88);
  backdrop-filter: blur(20px) saturate(140%);
  border-bottom: 1px solid var(--line);
  transition: transform .4s ease;
}
.nav-logo {
  font-family: var(--serif); font-size: 19px; font-weight: 400;
  color: var(--coal); letter-spacing: .04em;
  margin-right: auto;
}
.nav-logo em { font-style: italic; color: var(--ochre); }
.nav-links { display: flex; gap: 32px; list-style: none; }
.nav-links a {
  font-size: 13px; font-weight: 400; color: var(--smoke);
  text-decoration: none; letter-spacing: .04em;
  transition: color .2s;
}
.nav-links a:hover { color: var(--coal); }
.nav-cta {
  margin-left: 36px;
  padding: 8px 22px; border-radius: 40px;
  background: var(--coal); border: none;
  color: var(--cream); font-family: var(--sans);
  font-size: 13px; font-weight: 400; letter-spacing: .04em;
  cursor: pointer; transition: all .3s;
}
.nav-cta:hover { background: var(--ochre); }

/* ── HERO ────────────────────────────────────── */
.hero {
  min-height: 100vh;
  display: grid; grid-template-columns: 1fr 1fr;
  padding-top: 60px; overflow: hidden;
}

.hero-left {
  display: flex; flex-direction: column; justify-content: center;
  padding: 80px 64px 80px 80px;
  position: relative;
}

/* decorative vertical line */
.hero-left::before {
  content: '';
  position: absolute; top: 15%; bottom: 15%;
  right: 0; width: 1px;
  background: linear-gradient(to bottom, transparent, var(--line), var(--line), transparent);
}

.hero-season {
  display: inline-flex; align-items: center; gap: 10px;
  font-size: 11px; letter-spacing: .18em; text-transform: uppercase;
  color: var(--sage); margin-bottom: 36px;
}
.hero-season::before {
  content: '';
  width: 28px; height: 1px; background: var(--sage);
}

.hero-title {
  font-family: var(--serif);
  font-size: clamp(44px, 5.5vw, 78px);
  font-weight: 300; line-height: 1.08;
  letter-spacing: -.01em; color: var(--coal);
  margin-bottom: 24px;
}
.hero-title em { font-style: italic; color: var(--ochre); }

.hero-desc {
  font-size: 16px; color: var(--smoke); line-height: 1.75;
  max-width: 380px; margin-bottom: 44px; font-weight: 300;
}

.hero-actions { display: flex; align-items: center; gap: 20px; }
.btn-start {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 14px 30px; border-radius: 50px;
  background: var(--coal); border: none; color: var(--cream);
  font-family: var(--sans); font-size: 14px; font-weight: 400;
  letter-spacing: .04em; cursor: pointer; transition: all .35s;
}
.btn-start:hover { background: var(--ochre); transform: translateY(-2px); box-shadow: 0 12px 40px rgba(196,149,74,.3); }
.btn-start svg { width: 16px; height: 16px; }
.btn-link {
  font-size: 13px; color: var(--smoke); letter-spacing: .04em;
  cursor: pointer; border-bottom: 1px solid var(--line);
  transition: color .2s, border-color .2s; background: none; border-top: none; border-left: none; border-right: none;
  padding: 2px 0; font-family: var(--sans);
}
.btn-link:hover { color: var(--coal); border-color: var(--coal); }

/* Breadcrumb stats */
.hero-stats {
  display: flex; gap: 40px; margin-top: 60px;
  padding-top: 32px; border-top: 1px solid var(--line);
}
.stat-num {
  font-family: var(--serif); font-size: 32px; font-weight: 300;
  color: var(--coal); line-height: 1;
}
.stat-label { font-size: 12px; color: var(--mist); letter-spacing: .06em; margin-top: 4px; }

/* ── BREATHING WIDGET (hero right) ──────────────*/
.hero-right {
  background: var(--warm);
  display: flex; align-items: center; justify-content: center;
  position: relative; overflow: hidden;
}

/* soft organic blob bg */
.hero-right::before {
  content: '';
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 500px; height: 500px; border-radius: 60% 40% 55% 45% / 45% 55% 40% 60%;
  background: radial-gradient(circle at 40% 40%, rgba(196,149,74,.12), rgba(125,140,116,.08) 60%, transparent 80%);
  animation: morphBlob 12s ease-in-out infinite;
}
@keyframes morphBlob {
  0%,100% { border-radius: 60% 40% 55% 45% / 45% 55% 40% 60%; }
  33%  { border-radius: 45% 55% 40% 60% / 60% 40% 55% 45%; }
  66%  { border-radius: 55% 45% 60% 40% / 40% 60% 45% 55%; }
}

.breath-widget {
  position: relative; z-index: 1;
  display: flex; flex-direction: column; align-items: center; gap: 32px;
}

.breath-label-top {
  font-family: var(--serif); font-size: 13px; font-weight: 300;
  letter-spacing: .2em; text-transform: uppercase; color: var(--mist);
  text-align: center;
}

.breath-ring {
  position: relative;
  width: 220px; height: 220px;
  cursor: pointer; user-select: none;
}

.breath-svg {
  position: absolute; inset: 0; width: 100%; height: 100%;
}

.breath-track {
  fill: none; stroke: var(--linen); stroke-width: 1.5;
}
.breath-progress {
  fill: none; stroke: var(--ochre); stroke-width: 1.5;
  stroke-linecap: round;
  transform-origin: 50% 50%; transform: rotate(-90deg);
  stroke-dasharray: 565.5; /* 2π × 90 */
  stroke-dashoffset: 565.5;
  transition: stroke-dashoffset .1s linear;
}

.breath-inner {
  position: absolute; inset: 20px;
  border-radius: 50%; background: var(--cream);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 4px;
  box-shadow: inset 0 2px 20px rgba(196,149,74,.08), 0 8px 40px rgba(30,28,24,.06);
  animation: breathePulse 4s ease-in-out infinite;
}
@keyframes breathePulse {
  0%,100% { transform: scale(1); box-shadow: inset 0 2px 20px rgba(196,149,74,.08), 0 8px 40px rgba(30,28,24,.06); }
  50%      { transform: scale(1.06); box-shadow: inset 0 2px 20px rgba(196,149,74,.16), 0 16px 60px rgba(196,149,74,.15); }
}

.breath-phase {
  font-family: var(--serif); font-size: 15px; font-weight: 300;
  letter-spacing: .12em; text-transform: uppercase; color: var(--ochre);
}
.breath-count {
  font-family: var(--serif); font-size: 44px; font-weight: 300;
  color: var(--coal); line-height: 1; letter-spacing: -.02em;
}
.breath-sub {
  font-size: 10px; letter-spacing: .15em; text-transform: uppercase;
  color: var(--mist); font-weight: 400;
}

.breath-cycles {
  display: flex; gap: 8px;
}
.cycle-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--linen); border: 1px solid var(--ochre);
  transition: background .3s;
}
.cycle-dot.done { background: var(--ochre); }

.breath-hint {
  font-size: 11px; letter-spacing: .1em; text-transform: uppercase;
  color: var(--mist); font-weight: 300; text-align: center;
}

/* decorative circles in hero-right corner */
.deco-ring {
  position: absolute; border-radius: 50%;
  border: 1px solid var(--line); pointer-events: none;
}
.deco-ring-1 { width: 400px; height: 400px; top: -100px; right: -100px; opacity: .4; }
.deco-ring-2 { width: 200px; height: 200px; bottom: 40px; left: 40px; opacity: .25; }

/* ── RHYTHM OF THE DAY ───────────────────────── */
.rhythm-section {
  padding: 120px 80px;
  background: var(--coal);
  color: var(--cream);
  position: relative; overflow: hidden;
}
.rhythm-section::before {
  content: '';
  position: absolute; bottom: 0; right: 0;
  width: 400px; height: 400px; border-radius: 50%;
  background: radial-gradient(circle, rgba(196,149,74,.08), transparent 70%);
  transform: translate(30%, 30%);
}

.rhythm-header {
  display: flex; align-items: flex-end; justify-content: space-between;
  margin-bottom: 72px;
}
.rhythm-eyebrow {
  font-size: 11px; letter-spacing: .2em; text-transform: uppercase;
  color: var(--ochre); margin-bottom: 12px;
}
.rhythm-title {
  font-family: var(--serif); font-size: clamp(36px,4vw,60px);
  font-weight: 300; line-height: 1.1; color: var(--cream);
}
.rhythm-title em { font-style: italic; color: var(--ochre2); }
.rhythm-desc {
  max-width: 300px; font-size: 14px; color: rgba(245,240,232,.5);
  line-height: 1.7; font-weight: 300;
}

.rhythm-timeline {
  position: relative;
}

/* horizontal time line */
.timeline-track {
  position: relative; margin-bottom: 48px;
}
.timeline-line {
  height: 1px; background: rgba(245,240,232,.1);
  position: relative; margin: 0 0 0 80px;
}
.timeline-fill {
  position: absolute; left: 0; top: 0; height: 100%;
  background: linear-gradient(90deg, var(--ochre), var(--sage));
  width: 60%; transition: width .6s ease;
}
.timeline-labels {
  display: flex; justify-content: space-between;
  padding-left: 80px; margin-top: 12px;
}
.timeline-label {
  font-size: 11px; letter-spacing: .12em; text-transform: uppercase;
  color: rgba(245,240,232,.3); font-weight: 300;
}

.rhythm-slots {
  display: grid; grid-template-columns: 80px 1fr 1fr 1fr;
  gap: 0;
}
.slot-time-col {
  display: flex; flex-direction: column; gap: 24px;
  padding-top: 4px;
}
.slot-time {
  font-family: var(--serif); font-size: 13px; font-weight: 300;
  color: rgba(245,240,232,.3); letter-spacing: .06em;
  height: 100px; display: flex; align-items: flex-start;
}

.slot-col {
  border-left: 1px solid rgba(245,240,232,.06);
  padding: 0 16px; display: flex; flex-direction: column; gap: 12px;
}
.slot-col-label {
  font-size: 10px; letter-spacing: .2em; text-transform: uppercase;
  color: rgba(245,240,232,.3); padding-bottom: 12px;
  border-bottom: 1px solid rgba(245,240,232,.06);
  margin-bottom: 4px;
}

.slot-card {
  border-radius: 14px; padding: 16px 18px;
  cursor: pointer; transition: all .3s;
  position: relative; overflow: hidden;
}
.slot-card:hover { transform: translateY(-2px); }
.slot-card.morning { background: rgba(196,149,74,.12); border: 1px solid rgba(196,149,74,.2); }
.slot-card.midday  { background: rgba(125,140,116,.10); border: 1px solid rgba(125,140,116,.18); }
.slot-card.evening { background: rgba(245,240,232,.05); border: 1px solid rgba(245,240,232,.1); }
.slot-card.morning:hover { background: rgba(196,149,74,.2); }
.slot-card.midday:hover  { background: rgba(125,140,116,.18); }
.slot-card.evening:hover { background: rgba(245,240,232,.1); }

.slot-name { font-family: var(--serif); font-size: 16px; font-weight: 400; color: var(--cream); margin-bottom: 4px; }
.slot-dur  { font-size: 11px; letter-spacing: .08em; color: rgba(245,240,232,.4); margin-bottom: 8px; }
.slot-tags { display: flex; gap: 6px; flex-wrap: wrap; }
.slot-tag  {
  font-size: 10px; letter-spacing: .06em; padding: 2px 8px;
  border-radius: 20px; font-weight: 300;
}
.slot-tag.ochre { background: rgba(196,149,74,.2); color: var(--ochre2); }
.slot-tag.sage  { background: rgba(125,140,116,.2); color: var(--sage2); }
.slot-tag.mist  { background: rgba(245,240,232,.08); color: rgba(245,240,232,.5); }

/* ── PRACTICES ───────────────────────────────── */
.practices-section {
  padding: 120px 80px;
  background: var(--cream);
}
.practices-header { margin-bottom: 64px; }
.practices-eyebrow {
  font-size: 11px; letter-spacing: .2em; text-transform: uppercase;
  color: var(--sage); margin-bottom: 16px;
}
.practices-title {
  font-family: var(--serif); font-size: clamp(34px,4vw,58px);
  font-weight: 300; line-height: 1.1; color: var(--coal);
  max-width: 560px;
}
.practices-title em { font-style: italic; color: var(--ochre); }

.practices-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 2px; background: var(--line);
}
.practice-card {
  background: var(--cream); padding: 40px 36px;
  cursor: pointer; transition: all .35s;
  position: relative; overflow: hidden;
}
.practice-card:hover { background: var(--warm); }
.practice-card::after {
  content: '';
  position: absolute; bottom: 0; left: 36px; right: 36px; height: 1px;
  background: linear-gradient(90deg, var(--ochre), transparent);
  transform: scaleX(0); transform-origin: left;
  transition: transform .4s ease;
}
.practice-card:hover::after { transform: scaleX(1); }

.pc-icon {
  width: 48px; height: 48px; margin-bottom: 24px;
  opacity: .7; transition: opacity .3s;
}
.practice-card:hover .pc-icon { opacity: 1; }

.pc-name {
  font-family: var(--serif); font-size: 22px; font-weight: 400;
  color: var(--coal); margin-bottom: 6px; line-height: 1.2;
}
.pc-sanskrit {
  font-size: 11px; letter-spacing: .15em; text-transform: uppercase;
  color: var(--ochre); margin-bottom: 16px; font-weight: 300;
}
.pc-desc {
  font-size: 13px; color: var(--smoke); line-height: 1.7;
  font-weight: 300; margin-bottom: 24px;
}
.pc-meta {
  display: flex; gap: 16px; align-items: center;
}
.pc-dur {
  font-size: 12px; color: var(--mist); letter-spacing: .06em;
  display: flex; align-items: center; gap: 6px;
}
.pc-dur::before {
  content: '';
  width: 4px; height: 4px; border-radius: 50%;
  background: var(--ochre); flex-shrink: 0;
}
.pc-level {
  font-size: 11px; padding: 3px 10px; border-radius: 20px;
  background: var(--warm); color: var(--smoke); letter-spacing: .06em;
}

/* ── TEACHER BLOCK ───────────────────────────── */
.teacher-section {
  display: grid; grid-template-columns: 1fr 1fr;
  min-height: 560px; overflow: hidden;
}
.teacher-img {
  background: var(--linen);
  position: relative; overflow: hidden;
  display: flex; align-items: flex-end;
}
.teacher-img-el {
  width: 100%; height: 100%; object-fit: cover; display: block;
  filter: grayscale(20%) contrast(1.05);
}
.teacher-img-placeholder {
  width: 100%; height: 100%; min-height: 560px;
  background: linear-gradient(160deg, var(--linen) 0%, var(--warm) 100%);
  display: flex; align-items: center; justify-content: center;
}
.teacher-img-placeholder svg { width: 80px; height: 80px; opacity: .2; }
.teacher-img-caption {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 24px 36px;
  background: linear-gradient(to top, rgba(30,28,24,.5), transparent);
}
.teacher-img-name {
  font-family: var(--serif); font-size: 20px; font-weight: 400;
  color: var(--cream); letter-spacing: .04em;
}
.teacher-img-title { font-size: 12px; color: rgba(245,240,232,.6); letter-spacing: .1em; }

.teacher-content {
  background: var(--warm);
  padding: 80px 72px;
  display: flex; flex-direction: column; justify-content: center;
}
.teacher-eyebrow {
  font-size: 11px; letter-spacing: .2em; text-transform: uppercase;
  color: var(--sage); margin-bottom: 20px;
}
.teacher-quote {
  font-family: var(--serif); font-size: clamp(22px,2.5vw,34px);
  font-weight: 300; font-style: italic;
  line-height: 1.4; color: var(--coal); margin-bottom: 32px;
}
.teacher-quote::before { content: '«'; color: var(--ochre); }
.teacher-quote::after  { content: '»'; color: var(--ochre); }
.teacher-bio {
  font-size: 14px; color: var(--smoke); line-height: 1.75;
  font-weight: 300; margin-bottom: 40px;
}
.teacher-certs {
  display: flex; flex-wrap: wrap; gap: 10px;
}
.cert-pill {
  font-size: 11px; letter-spacing: .08em; padding: 6px 14px;
  border-radius: 30px; background: var(--cream);
  border: 1px solid var(--line); color: var(--smoke); font-weight: 300;
}

/* ── OFFERINGS / PRICE BLOCK ─────────────────── */
.offerings-section {
  padding: 120px 80px;
  background: var(--cream);
  border-top: 1px solid var(--line);
}
.offerings-header { text-align: center; margin-bottom: 64px; }
.offerings-eyebrow {
  font-size: 11px; letter-spacing: .2em; text-transform: uppercase;
  color: var(--ochre); margin-bottom: 16px;
}
.offerings-title {
  font-family: var(--serif); font-size: clamp(34px,4vw,58px);
  font-weight: 300; color: var(--coal); line-height: 1.1;
}
.offerings-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 20px; max-width: 1040px; margin: 0 auto;
}
.offering-card {
  border: 1px solid var(--line); border-radius: 24px;
  padding: 40px 36px; background: var(--cream);
  display: flex; flex-direction: column;
  transition: all .35s; cursor: pointer;
  position: relative; overflow: hidden;
}
.offering-card:hover { border-color: var(--ochre); transform: translateY(-4px); box-shadow: 0 24px 60px rgba(196,149,74,.1); }
.offering-card.featured {
  background: var(--coal); border-color: var(--coal);
}
.offering-card.featured:hover { border-color: var(--ochre); }
.of-badge {
  position: absolute; top: 24px; right: 24px;
  font-size: 10px; letter-spacing: .12em; text-transform: uppercase;
  padding: 4px 12px; border-radius: 20px;
  background: var(--ochre); color: var(--cream); font-weight: 500;
}
.of-name {
  font-family: var(--serif); font-size: 22px; font-weight: 400;
  color: var(--coal); margin-bottom: 8px;
}
.offering-card.featured .of-name { color: var(--cream); }
.of-price {
  font-family: var(--serif); font-size: 44px; font-weight: 300;
  color: var(--coal); line-height: 1; margin-bottom: 6px;
}
.offering-card.featured .of-price { color: var(--cream); }
.of-price sub { font-size: 16px; vertical-align: baseline; color: var(--mist); }
.offering-card.featured .of-price sub { color: rgba(245,240,232,.4); }
.of-period {
  font-size: 12px; color: var(--mist); margin-bottom: 28px; letter-spacing: .06em;
}
.offering-card.featured .of-period { color: rgba(245,240,232,.4); }
.of-divider { height: 1px; background: var(--line); margin: 0 0 24px; }
.offering-card.featured .of-divider { background: rgba(245,240,232,.1); }
.of-includes { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 32px; flex: 1; }
